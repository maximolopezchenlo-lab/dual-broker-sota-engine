# =====================================================================
# DUAL-BROKER SOTA ENGINE - AGENTIC COMPILER & EXECUTION RULES
# =====================================================================

[COMPILER_INVARIANTS]
target_typescript_version = "5.x"
target_java_version = "17"
target_python_version = ">=3.10"
package_manager_js = "npm"
build_tool_java = "maven"
virtualenv_python = "venv"

[COMPILATION_PIPELINES]
mcp_gateway_build = "npm run build --prefix mcp_gateway"
streaming_pipeline_build = "mvn clean package -f streaming_pipeline/pom.xml"
sandbox_transaccional_build = "npm run build --prefix sandbox_transaccional/web3_sandbox"

[EXECUTION_ALIASES]
start_infrastructure = "docker-compose up -d"
stop_infrastructure = "docker-compose down"
run_mcp_gateway = "npm run dev --prefix mcp_gateway"
run_core_agents = "python core_agents/src/main.py"
run_web3_sandbox = "npm run simulate --prefix sandbox_transaccional/web3_sandbox"

[VERIFICATION_CRITERIA]
lint_strictness = "enforce"
typecheck_required = true
test_coverage_threshold = 80
compilation_check_first = true

[SAFETY_CHECKLIST]
disable_live_trading_unless_authorized = true
verify_sandbox_running = false
simulate_before_sending_order = true
circuit_breaker_on_high_risk = true
risk_score_max = 50
kelly_sizing_multiplier = 0.25
jensen_shannon_alert_limit = 0.05
