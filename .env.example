# =====================================================================
# DUAL-BROKER SOTA ENGINE - ENVIRONMENT CONFIGURATION TEMPLATE (.env)
# =====================================================================

# ---------------------------------------------------------------------
# 1. Gateway & Environment Options
# ---------------------------------------------------------------------
NODE_ENV=production
MCP_SIMULATION_MODE=false # Set to true for local testing without real keys

# ---------------------------------------------------------------------
# 2. Bright Data API & Scraping Configuration
# ---------------------------------------------------------------------
BRIGHT_DATA_API_TOKEN=your_bright_data_api_token_here
BRIGHT_DATA_UNLOCKER_ZONE=unlocker
BRIGHT_DATA_BROWSER_ZONE=scraping_browser
BRIGHT_DATA_SERP_ENDPOINT=https://api.brightdata.com/serp
BRIGHT_DATA_BASE_TIMEOUT=15000
BRIGHT_DATA_MAX_RETRIES=3
BRIGHT_DATA_RATE_LIMIT=20
BRIGHT_DATA_PRO_MODE=true

# ---------------------------------------------------------------------
# 3. TradFi Brokerage (Alpaca) Configuration
# ---------------------------------------------------------------------
ALPACA_API_KEY=your_alpaca_key_id_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_ENDPOINT=https://api.alpaca.markets # Use https://paper-api.alpaca.markets for paper trading
ALPACA_MCP_SERVER_URI=ws://localhost:3001

# ---------------------------------------------------------------------
# 4. Web3 / EVM Blockchain Configuration (Polymarket CLOB)
# ---------------------------------------------------------------------
WEB3_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_key_here
POLYMARKET_MAKER_PRIVATE_KEY=0xyour_ethereum_private_key_here
POLYMARKET_MAKER_ADDRESS=0xyour_ethereum_address_here

# ---------------------------------------------------------------------
# 5. Infrastructure (Kafka, Qdrant & Flink)
# ---------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key_here
